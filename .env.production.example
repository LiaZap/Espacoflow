# ─────────────────────────────────────────────────────────────────────────────
# Espaço Flow — variáveis de PRODUÇÃO (EasyPanel). COPIE para o painel de cada
# serviço (App e Worker usam este bloco). NÃO comite valores reais — só placeholders.
#
# HOST INTERNO entre serviços do MESMO projeto EasyPanel = <projeto>_<servico>.
# Aqui o projeto se chama "espacoflow" (sem hífen, p/ evitar ambiguidade de DNS).
# FONTE DA VERDADE do host/credenciais: aba "Credentials" de cada banco no painel
# (botão copiar a "Internal Connection URL"). Se divergir destes exemplos, use a do painel.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# Postgres — banco do APP é "espaco_flow" (a Evolution usa outro banco, "evolution").
# Sem SSL: conexão é interna (rede do projeto).
DATABASE_URL=postgres://postgres:TROQUE_PG_SENHA@espacoflow_postgres:5432/espaco_flow

# Redis (fila BullMQ). db 0 (a Evolution usa db 6, isolado — ver env da Evolution).
REDIS_URL=redis://espacoflow_redis:6379
FILA_HABILITADA=true

# MongoDB (dados da IA). authSource=admin é OBRIGATÓRIO: o root do Mongo fica no banco "admin".
MONGO_URL=mongodb://mongo:TROQUE_MONGO_SENHA@espacoflow_mongo:27017/?authSource=admin

# MinIO (arquivos: comprovantes, recibos PDF, mídia). Conexão app→MinIO é interna (sem SSL).
# MINIO_PUBLIC_URL = domínio público do MinIO (API, porta 9000) JÁ INCLUINDO o bucket,
# pois é por ela que os arquivos abrem no navegador.
MINIO_ENDPOINT=espacoflow_minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=TROQUE_MINIO_ACCESS
MINIO_SECRET_KEY=TROQUE_MINIO_SECRET
MINIO_BUCKET=espaco-flow
MINIO_PUBLIC_URL=https://minio.seudominio.com.br/espaco-flow

# WhatsApp via Evolution API (Node v2.3.7).
# WHATSAPP_API_URL = app→Evolution (interno). WHATSAPP_API_TOKEN = AUTHENTICATION_API_KEY da Evolution.
# WHATSAPP_WEBHOOK_URL = endereço do NOSSO webhook como a Evolution o enxerga (interno).
# O token vai no header x-webhook-token E também na query ?token= (reforço automático no código).
WHATSAPP_PROVIDER=evolution
WHATSAPP_API_URL=http://espacoflow_evolution:8080
WHATSAPP_API_TOKEN=TROQUE_EVO_API_KEY
WHATSAPP_INSTANCIA=espaco-flow
WHATSAPP_WEBHOOK_URL=http://espacoflow_app:3000/api/whatsapp/webhook
WHATSAPP_WEBHOOK_VERIFY_TOKEN=TROQUE_WEBHOOK_TOKEN

# URL pública do app (HTTPS) — usada na tela de config e como fallback do webhook.
APP_URL=https://app.seudominio.com.br

# Claude (agente Hígia). Sem ela, o atendimento automático fica desligado (manual).
ANTHROPIC_API_KEY=sk-ant-TROQUE_SUA_CHAVE

# (Opcional) Sobrescreve as credenciais do owner criado pelo seed (npm run db:seed).
# SEED_OWNER_EMAIL=paulo@seudominio.com.br
# SEED_OWNER_SENHA=UmaSenhaForte!2026

# ─────────────────────────────────────────────────────────────────────────────
# Bloco SEPARADO — vai no serviço "evolution" (imagem evoapicloud/evolution-api:latest),
# NÃO no app/worker. AUTHENTICATION_API_KEY tem que ser igual a WHATSAPP_API_TOKEN acima.
# ─────────────────────────────────────────────────────────────────────────────
# SERVER_URL=http://espacoflow_evolution:8080
# AUTHENTICATION_API_KEY=TROQUE_EVO_API_KEY
# DATABASE_ENABLED=true
# DATABASE_PROVIDER=postgresql
# DATABASE_CONNECTION_URI=postgresql://postgres:TROQUE_PG_SENHA@espacoflow_postgres:5432/evolution
# DATABASE_CONNECTION_CLIENT_NAME=evolution
# DATABASE_SAVE_DATA_INSTANCE=true
# DATABASE_SAVE_DATA_NEW_MESSAGE=true
# CACHE_REDIS_ENABLED=true
# CACHE_REDIS_URI=redis://espacoflow_redis:6379/6
# CACHE_REDIS_PREFIX_KEY=evolution
# CACHE_LOCAL_ENABLED=false

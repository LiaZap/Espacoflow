# ───────────────────────────────────────────────────────────────
# Espaço Flow — variáveis de ambiente (copie para .env e ajuste)
# NUNCA commitar o .env real. Apenas este .example fica no git.
# ───────────────────────────────────────────────────────────────

# Banco (idêntico ao docker-compose.yml local). Porta 5433 no host (5432 já ocupado).
DATABASE_URL="postgres://dev:dev@localhost:5433/espaco_flow_dev"

# Fila FIFO (BullMQ / Redis)
REDIS_URL="redis://localhost:6379"
# "true" = webhook enfileira e o worker (npm run worker) processa em ordem (FIFO).
# "false"/vazio = processamento inline (dev sem worker).
FILA_HABILITADA="false"

# App
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Sessão (segredo p/ assinar cookies, se necessário). Gere um valor aleatório forte.
SESSION_SECRET="troque-por-um-segredo-aleatorio-bem-grande"

# Agente Hígia (LLM) — preencher quando integrar
# Modelo preferido do cliente: Claude (Anthropic) e/ou OpenAI
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
AGENTE_MODELO="claude-opus-4-8"

# WhatsApp (integração de mensageria — Evolution API / Cloud API)
# Vazio = modo "sandbox" (envios apenas logados; ideal para testar o fluxo).
WHATSAPP_PROVIDER="evolution"
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""
WHATSAPP_INSTANCIA="espaco-flow"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="defina-um-token-de-verificacao"

# Pix do Espaço Flow (instruções exibidas no fluxo de pagamento)
PIX_CHAVE=""
PIX_BENEFICIARIO="Felipe Geraldo Torres LTDA"
